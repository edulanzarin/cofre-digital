# Dev local (fora do Docker): copie para .env
# Suba só o banco com: docker compose up -d db
# (5433 no dev porque o db do flow já usa a 5432 — ver docker-compose.override.yml)
DATABASE_URL="postgresql://vault:vault_secret@localhost:5433/vault"

AUTH_SECRET="dev-secret-nao-usar-em-producao"

# Para o docker compose (opcional — tem defaults):
# POSTGRES_PASSWORD=vault_secret
# AUTH_SECRET=um-segredo-forte-aqui
# SEED_ADMIN_NAME=Eduardo Lanzarin
# SEED_ADMIN_EMAIL=eduardo.lanzarin@navecon.net.br
# SEED_ADMIN_PASSWORD="..."  (use aspas — senha com # sem aspas é cortada)
