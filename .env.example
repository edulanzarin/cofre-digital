# Nome da stack no Docker — não depende do nome da pasta.
COMPOSE_PROJECT_NAME=cofre-digital

# Portas publicadas no host. Faixa reservada do projeto: 4004 app / 5004 banco.
# O banco espelha o app trocando o 4 inicial por 5. Trocar aqui não exige rebuild.
APP_PORT=4004
DB_PORT=5004

# Dev local (fora do Docker): copie para .env e suba só o banco com
#   docker compose up -d db
DATABASE_URL="postgresql://vault:vault_secret@localhost:5004/vault"

AUTH_SECRET="dev-secret-nao-usar-em-producao"

# Para o docker compose (opcional — tem defaults):
# POSTGRES_PASSWORD=vault_secret
# AUTH_SECRET=um-segredo-forte-aqui
# SEED_ADMIN_NAME=Eduardo Lanzarin
# SEED_ADMIN_EMAIL=eduardo.lanzarin@navecon.net.br
# SEED_ADMIN_PASSWORD="..."  (use aspas — senha com # sem aspas é cortada)
